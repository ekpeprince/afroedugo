rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Community images: publicly readable, writeable by authenticated users (must be images under 5MB)
    match /community/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() 
                    && request.resource.contentType.matches('image/.*')
                    && request.resource.size < 5 * 1024 * 1024;
    }

    // Story images: publicly readable, authenticated users can upload (max 5MB images)
    match /stories/{allPaths=**} {
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.resource.contentType.matches('image/.*')
                    && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isAuthenticated();
    }

    // Default catch-all rule (secure by default)
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
