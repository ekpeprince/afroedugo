rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Profiles & Avatars: Publicly readable, writeable only if file name starts with user's UID
    match /profiles/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && fileName.matches(request.auth.uid + '_.*');
    }
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && fileName.matches(request.auth.uid + '_.*');
    }

    match /community/{fileName} {
      allow read: if true;
      allow create, update: if isAuthenticated() 
                    && request.resource.contentType.matches('image/.*')
                    && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isAuthenticated();
    }

    // Story images: publicly readable, writeable/deletable by owner only
    match /stories/{fileName} {
      allow read: if true;
      allow create, update: if isAuthenticated()
                    && request.resource.contentType.matches('image/.*')
                    && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isAuthenticated();
    }

    // Housing Images: publicly readable, writeable/deletable only if file starts with 'housing_<uid>_'
    match /housing_images/{fileName} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated()
                    && fileName.matches('housing_' + request.auth.uid + '_.*');
    }

    // Chats: Only accessible by authenticated participants of the conversation
    match /chats/{conversationId}/{fileName} {
      allow read, write: if isAuthenticated() 
                    && (request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.participants);
    }

    // Enrollments documents: writeable/deletable by owner only. NOT PUBLIC.
    match /enrollments/{fileName} {
      allow read: if isAuthenticated() && fileName.matches(request.auth.uid + '_.*');
      allow create, update, delete: if isAuthenticated() && fileName.matches(request.auth.uid + '_.*');
    }

    // Default secure catch-all rule
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Deny generic catch-all writes for security
    }
  }
}
